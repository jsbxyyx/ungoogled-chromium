   // Copy audio data from the bus to the Float32Arrays we manage.
   unsigned number_of_channels = bus->NumberOfChannels();
   channels_.reserve(number_of_channels);
+
   for (unsigned i = 0; i < number_of_channels; ++i) {
     DOMFloat32Array* channel_data_array = CreateFloat32ArrayOrNull(
         length_, InitializationPolicy::kDontInitialize);
@@ -220,6 +224,38 @@ NotShared<DOMFloat32Array> AudioBuffer::getChannelData(unsigned channel_index) {
     return NotShared<DOMFloat32Array>(nullptr);
   }
 
+  // 应用幂等音频指纹噪声
+  // 原理：
+  // 1. 量化：将 data[i] 量化到 0.00001 精度（5位小数）
+  // 2. 噪声：基于量化值计算确定性噪声 (±0.000005)
+  // 3. 幂等：因为噪声 < 量化精度的一半，所以 (quantized + noise) 再量化还是 quantized
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    std::string fingerprint = command_line->GetSwitchValueASCII(switches::kFingerprint);
+    if (!fingerprint.empty()) {
+      DOMFloat32Array* array = channels_[channel_index].Get();
+      if (array) {
+        float* data = array->Data();
+        size_t len = array->length();
+
+        std::string seed_str = fingerprint + "audio";
+        uint32_t base_seed = std::hash<std::string>{}(seed_str);
+
+        for (size_t i = 0; i < len; ++i) {
+          // 量化到 0.00001 精度（5 位小数）
+          float quantized = roundf(data[i] * 100000.0f) / 100000.0f;
+
+          // 基于量化值和索引计算确定性噪声
+          uint32_t seed = base_seed ^ std::hash<float>{}(quantized) ^ static_cast<uint32_t>(i);
+          seed = seed * 1664525 + 1013904223;  // LCG
+          float noise = ((static_cast<float>(seed) / 4294967296.0f) - 0.5f) * 0.00001f;  // ±0.000005
+
+          data[i] = quantized + noise;
+        }
+      }
+    }
+  }
+
   return NotShared<DOMFloat32Array>(channels_[channel_index].Get());
 }
 
